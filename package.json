{
  "name": "rebellious-burger-king-desktop-pet",
  "version": "1.0.1",
  "description": "叛逆汉堡大王 desktop pet packaged with Electron.",
  "main": "src/main.js",
  "author": "叛逆汉堡大王-桌面宠物",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check:assets": "node scripts/check-assets.js",
    "export:preview": "python scripts/export-preview-media.py",
    "smoke": "set REBELLIOUS_BURGER_KING_PET_SMOKE_TEST=1&& electron .",
    "package:win": "electron-builder --win portable --x64 --publish never",
    "package:mac": "electron-builder --mac dmg zip --universal --publish never"
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.rebelliousburgerking.desktop",
    "productName": "叛逆汉堡大王-桌面宠物",
    "artifactName": "叛逆汉堡大王-桌面宠物.${ext}",
    "files": [
      "src/**/*",
      "assets/**/*",
      "README.txt",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.entertainment",
      "identity": null
    },
    "portable": {
      "artifactName": "叛逆汉堡大王-桌面宠物.${ext}"
    }
  }
}
