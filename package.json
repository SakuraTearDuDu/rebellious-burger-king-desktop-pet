{
  "name": "snacky-desktop-pet",
  "version": "1.0.0",
  "description": "Snacky desktop pet packaged as a portable Windows app.",
  "main": "src/main.js",
  "author": "Snacky-桌面宠物",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check:assets": "node scripts/check-assets.js",
    "export:preview": "python scripts/export-preview-media.py",
    "smoke": "set SNACKY_PET_SMOKE_TEST=1&& electron .",
    "package:win": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.snackypet.desktop",
    "productName": "Snacky-桌面宠物",
    "artifactName": "Snacky-桌面宠物.${ext}",
    "files": [
      "src/**/*",
      "assets/**/*",
      "README.txt",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "Snacky-桌面宠物.${ext}"
    }
  }
}
